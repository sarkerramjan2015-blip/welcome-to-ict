# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DATABASE_URL: Required for Prisma to connect to SQLite.
# Example: file:./dev.db
DATABASE_URL="file:./dev.db"
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://icttoppers.com"

# Firebase web app config for Google sign-in.
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_FIREBASE_AUTH_DOMAIN"
VITE_FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_FIREBASE_STORAGE_BUCKET"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_FIREBASE_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"
VITE_FIREBASE_MEASUREMENT_ID="MY_FIREBASE_MEASUREMENT_ID"

# Google Analytics 4 measurement ID.
# Example: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# UddoktaPay Hosted Checkout server-side credentials.
# Do not prefix these with VITE_; they must stay private on the server/API route.
UDDOKTAPAY_API_URL="https://icttoppers.paymently.io/api/checkout-v2"
UDDOKTAPAY_API_KEY="MY_UDDOKTAPAY_API_KEY"

# Optional public URL only. Never expose the API key with a VITE_ prefix.
VITE_UDDOKTAPAY_URL="https://icttoppers.paymently.io/api/checkout-v2"

# Firebase Admin credentials for server-side enrollment writes after payment verification.
# Recommended for Vercel: paste the full service-account JSON into FIREBASE_SERVICE_ACCOUNT_KEY.
FIREBASE_SERVICE_ACCOUNT_KEY='{"project_id":"MY_FIREBASE_PROJECT_ID","client_email":"firebase-adminsdk@example.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\nMY_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"}'

# Alternative to FIREBASE_SERVICE_ACCOUNT_KEY:
# FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk@example.iam.gserviceaccount.com"
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMY_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
