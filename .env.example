# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DATABASE_URL: Required for Prisma to connect to SQLite.
# Example: file:./dev.db
DATABASE_URL="file:./dev.db"
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase web app config for Google sign-in.
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_FIREBASE_AUTH_DOMAIN"
VITE_FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_FIREBASE_STORAGE_BUCKET"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_FIREBASE_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"
VITE_FIREBASE_MEASUREMENT_ID="MY_FIREBASE_MEASUREMENT_ID"

# Google Analytics 4 measurement ID.
# Example: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
